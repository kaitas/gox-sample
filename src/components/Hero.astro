---
---

<section class="relative min-h-screen flex items-center justify-center overflow-hidden">
  <!-- Background Effects -->
  <div class="absolute inset-0">
    <div class="absolute inset-0 bg-gradient-to-br from-gox-black via-gox-black to-purple-900/20"></div>
    <div class="absolute top-1/4 left-1/4 w-96 h-96 bg-gox-gold/10 rounded-full blur-3xl"></div>
    <div class="absolute bottom-1/4 right-1/4 w-96 h-96 bg-gox-purple/10 rounded-full blur-3xl"></div>
  </div>
  
  <!-- Content -->
  <div class="relative z-10 text-center px-4 max-w-5xl mx-auto">
    <p class="font-display text-gox-gold text-sm md:text-base tracking-[0.3em] mb-6 opacity-80">
      HIGASHI-SHINJUKU, TOKYO
    </p>
    
    <h1 class="font-display text-5xl md:text-7xl lg:text-8xl font-black mb-6">
      <span class="text-gox-gold glow-text">CRYPTO</span>
      <br />
      <span class="text-white">LOUNGE</span>
      <br />
      <span class="text-gox-gold glow-text">GOX</span>
    </h1>
    
    <p class="text-lg md:text-xl text-white/70 max-w-2xl mx-auto mb-8 leading-relaxed">
      クリプトコミュニティが集い、学び、交流する場所。<br class="hidden md:block" />
      イベント開催・貸切利用・コワーキングに対応。
    </p>
    
    <p class="font-display text-sm md:text-base tracking-[0.2em] text-white/50 mb-12">
      MAY THE CRYPTO BE WITH YOU
    </p>
    
    <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
      <a 
        href="#rental" 
        class="group relative px-8 py-4 bg-gox-gold text-gox-black font-display font-bold text-lg rounded-full overflow-hidden transition-all duration-300 hover:scale-105 glow-gold"
      >
        <span class="relative z-10">貸切予約・お問い合わせ</span>
      </a>
      
      <a 
        href="#events" 
        class="px-8 py-4 border-2 border-gox-gold/50 text-gox-gold font-display font-bold text-lg rounded-full transition-all duration-300 hover:border-gox-gold hover:bg-gox-gold/10"
      >
        イベント情報
      </a>
    </div>
  </div>
  
  <!-- Scroll Indicator -->
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 float">
    <div class="w-6 h-10 border-2 border-gox-gold/50 rounded-full flex items-start justify-center p-2">
      <div class="w-1 h-3 bg-gox-gold rounded-full animate-bounce"></div>
    </div>
  </div>
</section>
