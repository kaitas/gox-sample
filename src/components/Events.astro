---
// WordPress REST API からイベントを取得
let events: any[] = [];
let fetchError = false;

try {
  const response = await fetch('https://cryptoloungegox.com/wp-json/wp/v2/event?per_page=6&_embed');
  if (response.ok) {
    events = await response.json();
  } else {
    fetchError = true;
  }
} catch (error) {
  fetchError = true;
  console.error('Failed to fetch events:', error);
}

// フォールバック用のサンプルイベント
const fallbackEvents = [
  {
    title: { rendered: 'bb Community Meetup 26' },
    date: '2026-03-14',
    excerpt: { rendered: 'bb 4周年記念オフラインミートアップ' },
    link: 'https://cryptoloungegox.com/event/',
    featured_image_url: 'https://cryptoloungegox.com/wp-content/uploads/2026/02/bb.jpeg'
  },
  {
    title: { rendered: 'CT Academy' },
    date: '2026-02-26',
    excerpt: { rendered: 'CT Academyを受講できるGOX PROについてはコチラ' },
    link: 'https://cryptoloungegox.com/event/',
    featured_image_url: 'https://cryptoloungegox.com/wp-content/uploads/2026/02/image.png'
  },
];

const displayEvents = events.length > 0 ? events : fallbackEvents;
---

<section id="events" class="py-24 relative">
  <div class="absolute inset-0 bg-gradient-to-b from-gox-black via-purple-900/5 to-gox-black"></div>
  
  <div class="relative z-10 max-w-7xl mx-auto px-4">
    <!-- Header -->
    <div class="text-center mb-16">
      <p class="font-display text-gox-purple text-sm tracking-[0.3em] mb-4">UPCOMING EVENTS</p>
      <h2 class="font-display text-4xl md:text-5xl font-bold text-white mb-6">
        イベント情報
      </h2>
      <p class="text-white/60 text-lg">
        GOXで開催される最新イベント
      </p>
    </div>
    
    <!-- Events Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 mb-12">
      {displayEvents.slice(0, 6).map((event: any) => {
        const title = event.title?.rendered || event.title;
        const excerpt = event.excerpt?.rendered?.replace(/<[^>]*>/g, '').slice(0, 80) || '';
        const imageUrl = event._embedded?.['wp:featuredmedia']?.[0]?.source_url || event.featured_image_url || '';
        const date = new Date(event.date).toLocaleDateString('ja-JP', { year: 'numeric', month: 'long', day: 'numeric' });
        
        return (
          <a 
            href={event.link}
            target="_blank"
            rel="noopener noreferrer"
            class="group bg-white/5 rounded-2xl overflow-hidden border border-white/10 hover:border-gox-gold/50 transition-all duration-300 hover:scale-[1.02]"
          >
            {imageUrl && (
              <div class="aspect-video overflow-hidden">
                <img 
                  src={imageUrl} 
                  alt={title}
                  class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500"
                  loading="lazy"
                />
              </div>
            )}
            <div class="p-6">
              <p class="text-gox-gold text-sm font-display mb-2">{date}</p>
              <h3 class="text-white font-bold text-lg mb-2 group-hover:text-gox-gold transition-colors" set:html={title}></h3>
              <p class="text-white/60 text-sm line-clamp-2">{excerpt}...</p>
            </div>
          </a>
        );
      })}
    </div>
    
    <!-- View All Button -->
    <div class="text-center">
      <a 
        href="https://cryptoloungegox.com/event/"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 px-8 py-4 border-2 border-gox-gold/50 text-gox-gold font-display font-bold rounded-full hover:bg-gox-gold/10 hover:border-gox-gold transition-all duration-300"
      >
        すべてのイベントを見る
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
        </svg>
      </a>
    </div>
  </div>
</section>

<style>
  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
