---
const links = [
  { label: 'ABOUT', href: '#about' },
  { label: 'EVENT', href: '#events' },
  { label: 'PRICE', href: '#price' },
  { label: 'GOX PRO', href: 'https://lp.cryptoloungegox.com/goxpro/' },
];

const socials = [
  { icon: 'twitter', href: 'https://twitter.com/groove_on_x', label: 'X (Twitter)' },
  { icon: 'discord', href: 'https://discord.gg/X6EbTMbE93', label: 'Discord' },
  { icon: 'instagram', href: 'https://www.instagram.com/cryptoloungegox/', label: 'Instagram' },
  { icon: 'line', href: 'https://lin.ee/2MvznpMl', label: 'LINE' },
];
---

<footer class="bg-gox-black border-t border-white/10 py-16">
  <div class="max-w-7xl mx-auto px-4">
    <div class="grid md:grid-cols-4 gap-12 mb-12">
      <!-- Logo & Description -->
      <div class="md:col-span-2">
        <a href="/" class="font-display text-4xl font-bold text-gox-gold glow-text">GOX</a>
        <p class="text-white/60 mt-4 leading-relaxed">
          CryptoLoungeGOXは、クリプトに関する情報交換やコミュニケーションを目的としたラウンジスペースです。
        </p>
        <p class="font-display text-sm text-white/30 mt-4 tracking-wider">
          MAY THE CRYPTO BE WITH YOU
        </p>
      </div>
      
      <!-- Links -->
      <div>
        <h4 class="font-display text-white font-bold mb-4">MENU</h4>
        <ul class="space-y-2">
          {links.map((link) => (
            <li>
              <a href={link.href} class="text-white/60 hover:text-gox-gold transition-colors">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>
      
      <!-- Contact -->
      <div>
        <h4 class="font-display text-white font-bold mb-4">CONTACT</h4>
        <a 
          href="https://lin.ee/2MvznpMl"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 bg-[#00C300] text-white px-6 py-3 rounded-full font-bold hover:bg-[#00E000] transition-colors"
        >
          <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor">
            <path d="M19.365 9.863c.349 0 .63.285.63.631 0 .345-.281.63-.63.63H17.61v1.125h1.755c.349 0 .63.283.63.63 0 .344-.281.629-.63.629h-2.386c-.345 0-.627-.285-.627-.629V8.108c0-.345.282-.63.627-.63h2.386c.349 0 .63.285.63.63 0 .349-.281.63-.63.63H17.61v1.125h1.755zm-3.855 3.016c0 .27-.174.51-.432.596-.064.021-.133.031-.199.031-.211 0-.391-.09-.51-.25l-2.443-3.317v2.94c0 .344-.279.629-.631.629-.346 0-.626-.285-.626-.629V8.108c0-.27.173-.51.43-.595.06-.023.136-.033.194-.033.195 0 .375.104.495.254l2.462 3.33V8.108c0-.345.282-.63.63-.63.345 0 .63.285.63.63v4.771zm-5.741 0c0 .344-.282.629-.631.629-.345 0-.627-.285-.627-.629V8.108c0-.345.282-.63.627-.63.349 0 .631.285.631.63v4.771zm-2.466.629H4.917c-.345 0-.63-.285-.63-.629V8.108c0-.345.285-.63.63-.63.349 0 .63.285.63.63v4.141h1.756c.348 0 .629.283.629.63 0 .344-.281.629-.629.629M24 10.314C24 4.943 18.615.572 12 .572S0 4.943 0 10.314c0 4.811 4.27 8.842 10.035 9.608.391.082.923.258 1.058.59.12.301.079.766.038 1.08l-.164 1.02c-.045.301-.24 1.186 1.049.645 1.291-.539 6.916-4.078 9.436-6.975C23.176 14.393 24 12.458 24 10.314"/>
          </svg>
          LINE公式
        </a>
        
        <!-- Social Icons -->
        <div class="flex gap-4 mt-6">
          <a href="https://twitter.com/groove_on_x" target="_blank" rel="noopener" class="w-10 h-10 rounded-full bg-white/10 flex items-center justify-center text-white/60 hover:bg-gox-gold hover:text-gox-black transition-all">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
          </a>
          <a href="https://discord.gg/X6EbTMbE93" target="_blank" rel="noopener" class="w-10 h-10 rounded-full bg-white/10 flex items-center justify-center text-white/60 hover:bg-[#5865F2] hover:text-white transition-all">
