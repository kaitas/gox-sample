      <h4 class="font-display text-white/50 text-sm mb-4">運営会社</h4>
      <div class="flex flex-wrap gap-6 text-white/40 text-sm">
        <a href="https://t2web.co.jp/" target="_blank" rel="noopener" class="hover:text-white transition-colors">T2WEB株式会社</a>
        <a href="https://rokubunnoni.com/" target="_blank" rel="noopener" class="hover:text-white transition-colors">株式会社ロクブンノニ</a>
      </div>
    </div>
    
    <!-- Copyright -->
    <div class="text-center text-white/30 text-sm">
      © {new Date().getFullYear()} Crypto Lounge GOX. All rights reserved.
    </div>
  </div>
</footer>
