---
---

<section id="rental" class="py-24 relative overflow-hidden">
  <!-- Background -->
  <div class="absolute inset-0 bg-gradient-to-b from-gox-black via-green-900/10 to-gox-black"></div>
  
  <div class="relative z-10 max-w-6xl mx-auto px-4">
    <!-- Header -->
    <div class="text-center mb-16">
      <p class="font-display text-[#00C300] text-sm tracking-[0.3em] mb-4">RENTAL INQUIRY</p>
      <h2 class="font-display text-4xl md:text-5xl font-bold text-white mb-6">
        貸切予約・お問い合わせ
      </h2>
      <p class="text-white/60 text-lg max-w-2xl mx-auto">
        イベント開催、貸切利用のご相談は<br class="md:hidden" />LINE公式アカウントで承ります
      </p>
    </div>
    
    <!-- Main CTA Card -->
    <div class="max-w-2xl mx-auto">
      <div class="gradient-border">
        <div class="p-8 md:p-12 text-center">
          <!-- LINE Icon -->
          <div class="w-24 h-24 mx-auto mb-8 bg-[#00C300] rounded-3xl flex items-center justify-center shadow-2xl shadow-green-500/30">
            <svg class="w-14 h-14 text-white" viewBox="0 0 24 24" fill="currentColor">
              <path d="M19.365 9.863c.349 0 .63.285.63.631 0 .345-.281.63-.63.63H17.61v1.125h1.755c.349 0 .63.283.63.63 0 .344-.281.629-.63.629h-2.386c-.345 0-.627-.285-.627-.629V8.108c0-.345.282-.63.627-.63h2.386c.349 0 .63.285.63.63 0 .349-.281.63-.63.63H17.61v1.125h1.755zm-3.855 3.016c0 .27-.174.51-.432.596-.064.021-.133.031-.199.031-.211 0-.391-.09-.51-.25l-2.443-3.317v2.94c0 .344-.279.629-.631.629-.346 0-.626-.285-.626-.629V8.108c0-.27.173-.51.43-.595.06-.023.136-.033.194-.033.195 0 .375.104.495.254l2.462 3.33V8.108c0-.345.282-.63.63-.63.345 0 .63.285.63.63v4.771zm-5.741 0c0 .344-.282.629-.631.629-.345 0-.627-.285-.627-.629V8.108c0-.345.282-.63.627-.63.349 0 .631.285.631.63v4.771zm-2.466.629H4.917c-.345 0-.63-.285-.63-.629V8.108c0-.345.285-.63.63-.63.349 0 .63.285.63.63v4.141h1.756c.348 0 .629.283.629.63 0 .344-.281.629-.629.629M24 10.314C24 4.943 18.615.572 12 .572S0 4.943 0 10.314c0 4.811 4.27 8.842 10.035 9.608.391.082.923.258 1.058.59.12.301.079.766.038 1.08l-.164 1.02c-.045.301-.24 1.186 1.049.645 1.291-.539 6.916-4.078 9.436-6.975C23.176 14.393 24 12.458 24 10.314"/>
            </svg>
          </div>
          
          <h3 class="font-display text-2xl md:text-3xl font-bold text-white mb-4">
            LINE公式アカウント
          </h3>
          
          <p class="text-white/60 mb-8 leading-relaxed">
            貸切のご相談、空き状況の確認、お見積りなど<br />
            お気軽にお問い合わせください
          </p>
          
          <!-- Benefits -->
          <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-10">
            <div class="bg-white/5 rounded-xl p-4">
              <div class="text-[#00C300] font-display text-2xl font-bold mb-1">24h</div>
              <div class="text-white/60 text-sm">いつでも送信OK</div>
            </div>
            <div class="bg-white/5 rounded-xl p-4">
              <div class="text-[#00C300] font-display text-2xl font-bold mb-1">迅速</div>
              <div class="text-white/60 text-sm">スピード対応</div>
            </div>
            <div class="bg-white/5 rounded-xl p-4">
              <div class="text-[#00C300] font-display text-2xl font-bold mb-1">簡単</div>
              <div class="text-white/60 text-sm">チャットで相談</div>
            </div>
          </div>
          
          <!-- CTA Button -->
          <a 
            href="https://lin.ee/2MvznpMl" 
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-3 bg-[#00C300] hover:bg-[#00E000] text-white font-bold text-xl px-10 py-5 rounded-full transition-all duration-300 hover:scale-105 shadow-2xl shadow-green-500/30"
          >
            <svg class="w-7 h-7" viewBox="0 0 24 24" fill="currentColor">
              <path d="M19.365 9.863c.349 0 .63.285.63.631 0 .345-.281.63-.63.63H17.61v1.125h1.755c.349 0 .63.283.63.63 0 .344-.281.629-.63.629h-2.386c-.345 0-.627-.285-.627-.629V8.108c0-.345.282-.63.627-.63h2.386c.349 0 .63.285.63.63 0 .349-.281.63-.63.63H17.61v1.125h1.755zm-3.855 3.016c0 .27-.174.51-.432.596-.064.021-.133.031-.199.031-.211 0-.391-.09-.51-.25l-2.443-3.317v2.94c0 .344-.279.629-.631.629-.346 0-.626-.285-.626-.629V8.108c0-.27.173-.51.43-.595.06-.023.136-.033.194-.033.195 0 .375.104.495.254l2.462 3.33V8.108c0-.345.282-.63.63-.63.345 0 .63.285.63.63v4.771zm-5.741 0c0 .344-.282.629-.631.629-.345 0-.627-.285-.627-.629V8.108c0-.345.282-.63.627-.63.349 0 .631.285.631.63v4.771zm-2.466.629H4.917c-.345 0-.63-.285-.63-.629V8.108c0-.345.285-.63.63-.63.349 0 .63.285.63.63v4.141h1.756c.348 0 .629.283.629.63 0 .344-.281.629-.629.629M24 10.314C24 4.943 18.615.572 12 .572S0 4.943 0 10.314c0 4.811 4.27 8.842 10.035 9.608.391.082.923.258 1.058.59.12.301.079.766.038 1.08l-.164 1.02c-.045.301-.24 1.186 1.049.645 1.291-.539 6.916-4.078 9.436-6.975C23.176 14.393 24 12.458 24 10.314"/>
            </svg>
            友だち追加して問い合わせる
          </a>
          
          <p class="text-white/40 text-sm mt-6">
            ※ 営業時間外のお問い合わせは翌営業日に返信いたします
          </p>
        </div>
      </div>
    </div>
    
    <!-- Quick Info -->
    <div class="mt-12 grid grid-cols-1 md:grid-cols-2 gap-6 max-w-3xl mx-auto">
      <div class="bg-white/5 rounded-2xl p-6 border border-white/10">
        <h4 class="font-display text-gox-gold text-lg mb-3">貸切プラン</h4>
        <ul class="space-y-2 text-white/70">
          <li class="flex justify-between">
            <span>平日昼部</span>
            <span class="text-white">¥12,000/h〜</span>
          </li>
          <li class="flex justify-between">
            <span>休日夜部</span>
            <span class="text-white">¥20,000/h〜</span>
          </li>
        </ul>
      </div>
      <div class="bg-white/5 rounded-2xl p-6 border border-white/10">
        <h4 class="font-display text-gox-gold text-lg mb-3">収容人数</h4>
        <ul class="space-y-2 text-white/70">
          <li class="flex justify-between">
            <span>スタンディング</span>
            <span class="text-white">最大100名</span>
          </li>
          <li class="flex justify-between">
            <span>着席</span>
            <span class="text-white">約60名</span>
          </li>
        </ul>
      </div>
    </div>
  </div>
</section>
